# Database (SQLite for local dev — see README for production options)
DATABASE_URL="file:./prisma/dev.db"

# NextAuth
NEXTAUTH_SECRET="your-secret-here-run-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Stripe — get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Resend — get key from https://resend.com/api-keys
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="hello@emmafrey.com"

# Site URL (update for production)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Disable the one-time seed endpoint after first use
# DISABLE_SEED="true"
